# E2E credentials for Playwright flows.
# Copy these into .env.local (or set as CI secrets).
E2E_AUTH_EMAIL=
E2E_AUTH_PASSWORD=

# Optional explicit owner credentials (fallbacks to E2E_AUTH_*).
E2E_OWNER_EMAIL=
E2E_OWNER_PASSWORD=

# Required for join/leave flow in Phase 3.
E2E_ATTENDEE_EMAIL=
E2E_ATTENDEE_PASSWORD=

